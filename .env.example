# SQL Lint Service 环境变量配置

# 服务配置
ENABLE_HOT_RELOAD=true
HOT_RELOAD_DEBOUNCE=0.5
PORT=5000

# 日志配置
LOG_LEVEL=INFO

# 优化配置
TIMEOUT_SECONDS=5
MAX_SQL_SIZE_MB=10
ENABLE_SAMPLING=true
SAMPLING_THRESHOLD_KB=100
CACHE_SIZE=100

# Docker Compose配置（用于docker-compose.yml）
COMPOSE_PROJECT_NAME=sql-lint-service